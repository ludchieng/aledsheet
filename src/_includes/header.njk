<header class="header {% if id == "home" %}sticky{% else %}fixed{% endif %} flex h-16 items-center top-0 w-full z-30 py-2 border-b border-gray-800">
  <div class="w-full relative max-w-screen-xl mx-auto px-6 flex flex-row items-center">
    
    <div class="header-left mr-2 w-1/5 flex-shrink-0">
      <a class="header-logo block" href="/" title="logo aledsheet">
        aledsheet
      </a>
    </div>

    <div class="search relative mr-2 flex-grow max-w-2xl sm:mr-6">
      <input class="search-input appearance-none w-full inline-block py-1 px-4 border-2 outline-none rounded-full" placeholder="Search..." />
      <div class="search-results fixed left-4 right-4 top-100 p-2 mt-2 rounded-lg shadow-2xl text-sm lg:absolute lg:left-auto lg:right-auto lg:min-w-full" data-state="no-term"></div>
    </div>

    <!-- large window width -->
    <nav class="header-nav hidden lg:flex">

      <ul class="menu flex flex-col lg:flex-row items-center list-reset text-base">
        <li>
          <a class="inline-block py-3 px-5 rounded align-middle" href="{{ site.urls.github }}">
            {% include "assets/images/icons/github.svg" %}
          </a>
        </li>
      </ul>

    </nav>

    <!-- small window width -->
    <nav class="header-nav lg:hidden flex">

      <ul class="menu flex flex-row items-center list-reset text-sm">
        <li>
          <a class="inline-block p-2 mr-1 rounded align-middle" href="{{ site.urls.github }}">
            {% include "assets/images/icons/github.svg" %}
          </a>
        </li>
        <li>
          <button class="menu-toggle inline-block py-1 pl-2">
            <svg viewBox="0 0 24 24" width="24" height="24" xmlns="http://www.w3.org/2000/svg">
              <line class="line1" x1="0" y1="8" x2="24" y2="8" />
              <line class="line2" x1="0" y1="16" x2="24" y2="16" />
            </svg>
          </button>
        </li>

      </ul>

    </nav>

  </div>
</header>
