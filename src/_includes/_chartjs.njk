<!-- ChartJS & markdown-it-charts -->
<script type="text/javascript" src="https://cdn.jsdelivr.net/npm/jquery@3.5.1/dist/jquery.min.js"></script>
<script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/2.9.3/Chart.bundle.min.js"></script>
<script>
    $(() => {
        var mainColor = getComputedStyle(document.body).getPropertyValue('--main-color');
        var bgColor = getComputedStyle(document.body).getPropertyValue('--background-color');
        var mainFont = getComputedStyle(document.body).getPropertyValue('--main-font');
        var fontSize = getComputedStyle(document.body).getPropertyValue('--font-size');
        var count = $('.chartjs').length;
        var myChartsJs = [];
        
        Chart.defaults.global.defaultFontFamily = mainFont;
        Chart.defaults.global.defaultFontColor = mainColor;
        Chart.defaults.global.defaultFontSize = fontSize;

        for (var i = 0; i < count; i++) {
            var ctx = $('.chartjs')[i].getContext('2d');
            myChartsJs[i] = new Chart(ctx, $.parseJSON($($('.chartjs')[i])[0].innerHTML));
        }
    });
</script>